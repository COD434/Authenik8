{
  "name": "Authenik8-API",
  "version": "0.0.1",
  "main": "server.ts",
  "description":"This a stand alone API and a part of the Authenik8 ecosystem have fun with it",
  "keywords":["api","starter", "backend-starter","authentication","typescript","A8"],
  "author":"Karabo Seeisa",
  "license":"MIT",
  "publishConfig":{
  "access":"public"
  },
  "scripts": {
    "build": "tsc",
    "devStart": "nodemon server.ts",
    "start": "node dist/server.js",
    "GoGo": "node dist/prisma/config/emailConsumer.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha --require ts-node/register --require tests/setup.ts \"tests/**/*.unit.test.ts\"",
    "test:e2e": "mocha --require ts-node/register --require tests/setup.ts --require tests/hooks.ts \"tests/**/*.e2e.test.ts\"",
    "test:robustness": "TEST_SKIP_DATABASE=true mocha --require ts-node/register --require tests/setup.ts --require tests/hooks.ts \"tests/robustness.test.ts\"",
    "pretest:integration": "node tests/prepare-integration.cjs",
    "test:integration": "mocha --require ts-node/register --require tests/setup.ts --require tests/hooks.ts \"tests/**/*.e2e.test.ts\" \"tests/robustness.test.ts\"",
    "release": "semantic-release"
  },
  "overrides": {
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  },
